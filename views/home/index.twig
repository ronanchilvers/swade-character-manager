{% extends 'layouts/default.twig' %}

{% do add_script('/javascript/character-delete.js') %}

{% block content %}
<h2>Characters</h2>
{% if characters|length > 0 %}
<div class="cards cards--uniform cards--character">
{% for character in characters %}
    <div class="card card--selected">
        <div class="card__inner">
            {% if character.campaign %}
                <div class="card__campaign">
                    Campaign: <span><a href="{{ get_url('campaigns_view', {hash: campaigns[character.campaign]['hash'] }) }}">{{ campaigns[character.campaign]['name'] }}</a></span>
                </div>
            {% endif %}
            <div class="card__title">{{ character.name }}</div>
            <div class="card__content{% if character.concept|length == 0 %} card__content--empty{% endif %}">
                {% if character.concept|length > 0 %}{{ character.concept }}{% else %}No concept yet{% endif %}
            </div>
            <div class="card__footer">
                <a class="button" href="{{ get_url('characters_sheet', {hash: character.hash}) }}">View sheet</a>
                <a class="button" href="{{ get_url('characters_settings', {hash: character.hash}) }}">Edit</a>
                {% if not character.campaign %}
                <button class="button button--danger"
                        type="button"
                        data-character-delete-open="{{ character.hash }}">Delete</button>
                {% endif %}
            </div>
        </div>
    </div>
    {% if not character.campaign %}
    <dialog class="character-delete"
            aria-labelledby="character-delete-title-{{ character.hash }}"
            data-character-delete-dialog="{{ character.hash }}"
            data-character-name="{{ character.name|e('html_attr') }}">
        <form class="character-delete__form"
              method="post"
              action="{{ get_url('characters_delete', {hash: character.hash}) }}">
            <h2 class="character-delete__title" id="character-delete-title-{{ character.hash }}">Delete {{ character.name }}?</h2>
            <p class="character-delete__body">
                This permanently deletes the character and all sheet data. Type <strong>{{ character.name }}</strong> to confirm.
            </p>
            <label class="field">
                <span class="field__label">Character name</span>
                <input class="field__input"
                       type="text"
                       name="confirm_name"
                       autocomplete="off"
                       data-character-delete-input>
            </label>
            <div class="character-delete__buttons">
                <button class="button" type="button" data-character-delete-cancel>Cancel</button>
                <button class="button button--danger" type="submit" data-character-delete-submit disabled>Delete character</button>
            </div>
        </form>
    </dialog>
    {% endif %}
{% endfor %}
    <div class="card">
        <div class="card__inner">
            <div class="card__title">Create a character</div>
            <div class="card__content card__content--empty">
                Create a new character and set off on a new adventure!
            </div>
            <div class="card__footer">
                <a class="button button--primary button--full" href="{{ get_url('characters_new') }}">Create a Character</a>
            </div>
        </div>
    </div>
</div>
{% else %}
    <div class="home__empty">
        <h2 class="home__empty__title">No characters yet</h2>
        <p class="home__empty__body">Your roster is empty. Roll up your first hero to get started.</p>
        <a class="button button--primary" href="{{ get_url('characters_new') }}">Create one now</a>
    </div>
{% endif %}
{% endblock %}
