{% extends 'layouts/default.twig' %}

{% do add_stylesheet('/css/campaign.css') %}

{% block content %}
<section id="wrapper__inner" class="campaigns-view">
    <div class="section__header">
        <h2>{{ campaign.name }}</h2>
        {% if is_owner or is_superuser %}
        <aside class="invite-link">
            <div class="invite-link__panel">
                <p class="invite-link__url js-invite-link">{{ invite_url }}</p>
                <p class="small">Send this link to players to invite them to join your campaign</p>
            </div>
            <div class="invite-link__panel invite-link__panel--links">
                <a href="#">Copy Link</a>
                <a href="{{ get_url('campaigns_reset', { hash: campaign.hash })}}">Reset Link</a>
            </div>
        </aside>
        {% endif %}

    </div>

    {% if campaign.description|length > 0 %}
    <p>{{ campaign.description }}</p>
    {% endif %}

    <hr />

    <h3>Roster</h3>
    {% if roster|length > 0 %}
    <div class="cards">
    {% for row in roster %}
        <div class="card">
            <div class="card__inner">
                <div class="card__title">
                    {% if row.user %}
                    {{ row.user.firstname }} {{ row.user.lastname }}
                    {% else %}
                    Unknown user
                    {% endif %}
                    <span class="admin-pill">{{ row.member.role|title }}</span>
                </div>
                <div class="card__content">
                    {% if row.characters|length > 0 %}
                    <ul>
                    {% for character in row.characters %}
                        <li>
                            {% if character.user == session.user.id %}
                            <a href="{{ get_url('characters_sheet', {hash: character.hash}) }}">{{ character.name }}</a>
                            {% else %}
                            {{ character.name }}
                            {% endif %}
                        </li>
                    {% endfor %}
                    </ul>
                    {% else %}
                    No linked characters
                    {% endif %}
                </div>
                {% if row.user and row.user.id == session.user.id and row.characters|length > 0 %}
                <div class="card__footer">
                    {% for character in row.characters %}
                    <form method="post" action="{{ get_url('campaigns_leave_character', {hash: campaign.hash, character_hash: character.hash}) }}">
                        <button class="button" type="submit">Remove {{ character.name }}</button>
                    </form>
                    {% endfor %}
                </div>
                {% endif %}
            </div>
        </div>
    {% endfor %}
    </div>
    {% else %}
    <p>No members yet.</p>
    {% endif %}

    {% if is_member %}
    <h3>Add Character</h3>
    {% if available_characters|length > 0 %}
    <form method="post" action="{{ get_url('campaigns_add_character', {hash: campaign.hash}) }}">
        <div class="field">
            <label class="field__label">Character</label>
            <div class="field__inner">
                <select class="field__input" name="character_hash">
                    <option>Select&hellip;</option>
                {% for character in available_characters %}
                    <option value="{{ character.hash }}">{{ character.name }}</option>
                {% endfor %}
                </select>
            </div>
        </div>
        <button class="button button--primary" type="submit">Add Character</button>
    </form>
    {% else %}
    <p>You have no unassigned characters available.</p>
    {% endif %}

    <h3>Leave Campaign</h3>
    {% if can_leave %}
    <form method="post" action="{{ get_url('campaigns_leave', {hash: campaign.hash}) }}">
        <button class="button button--danger" type="submit">Leave Campaign</button>
    </form>
    {% else %}
    <p>Remove your characters from this campaign before leaving.</p>
    {% endif %}
    {% endif %}
</section>
{% endblock %}
