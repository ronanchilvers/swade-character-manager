<div class="toast__container">
    {% for toast in session.getFlashes() %}
    <div class="toast toast--{{ toast.type }}">
        <div class="toast__close">&#x2715;</div>
        <div class="toast__heading">
            {{ toast.type|capitalize }}
        </div>
        <div class="toast__message">
            {{ toast.message }}
        </div>
    </div>
    {% endfor %}
</div>
