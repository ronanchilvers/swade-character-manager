{% if budgets %}
<div class="budgets">
    {% for budget in budgets %}
    <div class="budget__panel budget__panel--{{ budget.id }}">
        <div class="budget__label">{{ budget.label }} - {{ budget.value }}/{{ budget.max }}</div>
        <div class="budget__value">
            <progress class="progress js-budget-progress" data-budget="{{ budget.id }}" value="{{ budget.value }}" max="{{ budget.max }}"></progress>
        </div>
    </div>
{% endfor %}
</div>
{% endif %}
