{% extends 'layouts/character/builder.twig' %}

{% block page %}

<div class="panel">
    <h2 class="panel__title">Character Concept</h2>
    <div class="panel__content">
    <p>Mauris congue, ante eu feugiat facilisis, nunc felis sagittis dui,
    vitae maximus ante eros sed quam. Suspendisse consequat, risus eget
    commodo tincidunt, diam mauris luctus mi, eu dapibus erat dolor sit
    amet felis. Quisque vitae mollis tellus, a mattis risus. Ut ullamcorper
    dolor ut placerat volutpat. Curabitur luctus cursus ligula, ut fringilla
    erat placerat eget.</p>
    </div>
</div>

<form class="form" method="post" action="">
    <div class="field {% if field_has_error('name', errors) %}field--error{% endif %}">
        <label class="field__label">Your character's name</label>
        <div class="field__inner">
            <input class="field__input" type="text" name="name" value="{{ entity.name }}"/>
        </div>
        <p class="field__error">This field is required</p>
    </div>

    <div class="form__buttons form__buttons--floating">
        <a class="button" href="{{ get_url('home_page') }}">Cancel</a>
        <button class="button button--primary" type="submit">Save and Continue...</button>
    </div>

</form>
{% endblock %}
