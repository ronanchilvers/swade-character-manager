{% extends 'layouts/character/builder.twig' %}

{% do add_script('/javascript/edges.js') %}

{% set back_url = get_url('characters_skills', {hash: entity.hash}) %}
{% set next_label = "Save" %}

{% block page %}
<div class="panel">
    <h2 class="panel__title">Edges</h2>
    <div class="panel__content">
        <p>Edges are the special abilities, training, and advantages that make your hero stand out. Some improve core actions, some unlock new options, and some are only available once your character meets the right prerequisites.</p>
        <p>One-time Edges use a single Selected toggle. Repeatable Edges use a counter so you can add or remove each additional purchase directly from the card.</p>
    </div>
</div>

{% for category, edges in edges_by_category %}
<section class="edges-group">
    <h3 class="edges-group__title">{{ category|replace({'_': ' '})|title }}</h3>
    <div class="cards">
        {% for edge in edges %}
        {% set isSelected = selected[edge.id]|default(0) > 0 %}
        <div class="card card--skill card--edge">
            <div class="card__inner">
                <div class="card__title card__title--collapsible card__title--collap1sed{% if isSelected %} card__title--selected{% endif %}">{{ edge.name }}</div>
                <div class="card__content">
                    {% if edge.summary %}
                    <p>{{ edge.summary }}</p>
                    {% endif %}

                    {% if edge.requirements %}
                    <div class="card__section">
                        <h4 class="card__subtitle">Requirements</h4>
                        <ul class="card__list">
                            {% for requirement in edge.requirements %}
                            {% set requirement_value = requirement.value %}
                            {% if requirement.value is iterable %}
                            {% set requirement_value = requirement.target == 'one_of'
                                ? requirement.value|join(' or ')
                                : requirement.value|join(', ') %}
                            {% endif %}
                            <li>
                                {% if requirement.type == 'rank' %}
                                {{ requirement_value }} rank
                                {% elseif requirement.type == 'attribute' or requirement.type == 'trait' %}
                                {{ requirement.target }} {{ requirement_value }}
                                {% elseif requirement.type == 'edge' %}
                                Requires {{ requirement_value }}
                                {% elseif requirement.type == 'arcane_background' %}
                                Arcane Background: {{ requirement_value }}
                                {% elseif requirement.type == 'wild_card' %}
                                Wild Card
                                {% elseif requirement.type == 'hindrance_any_of' %}
                                Hindrance: {{ requirement_value }}
                                {% elseif requirement.type == 'special' and requirement.target == 'one_of' %}
                                One of: {{ requirement_value }}
                                {% else %}
                                {{ requirement.type|replace({'_': ' '})|title }}: {{ requirement_value }}
                                {% endif %}
                            </li>
                            {% endfor %}
                        </ul>
                    </div>
                    {% endif %}

                    {% if edge.effects %}
                    <div class="card__section">
                        <h4 class="card__subtitle">Effects</h4>
                        <ul class="card__list">
                            {% for effect in edge.effects %}
                            <li>{{ effect.details }}</li>
                            {% endfor %}
                        </ul>
                    </div>
                    {% endif %}

                    {% if edge.notes %}
                    <div class="card__section">
                        <h4 class="card__subtitle">Notes</h4>
                        <ul class="card__list">
                            {% for note in edge.notes %}
                            <li>{{ note }}</li>
                            {% endfor %}
                        </ul>
                    </div>
                    {% endif %}
                </div>
                <div class="card__footer card__footer--no-border">
                    {% if edge.repeatable %}
                    <div class="edge-counter js-edge-counter">
                        <input
                            id="edge_{{ edge.id }}"
                            name="edges[{{ edge.id }}]"
                            type="hidden"
                            value="{{ selected[edge.id]|default(0) }}"
                            class="js-edge-input"
                        />
                        <button
                            class="edge-counter__button js-edge-adjust"
                            type="button"
                            data-direction="-1"
                            aria-label="Decrease {{ edge.name }}"
                            {% if selected[edge.id]|default(0) <= 0 %}disabled{% endif %}
                        >&minus;</button>
                        <div class="edge-counter__value" aria-live="polite">
                            <span class="edge-counter__count js-edge-value">{{ selected[edge.id]|default(0) }}</span>
                        </div>
                        <button
                            class="edge-counter__button js-edge-adjust"
                            type="button"
                            data-direction="1"
                            aria-label="Increase {{ edge.name }}"
                        >+</button>
                    </div>
                    {% else %}
                    <div class="edge-toggle js-edge-toggle">
                        <input
                            id="edge_{{ edge.id }}"
                            name="edges[{{ edge.id }}]"
                            type="hidden"
                            value="{{ selected[edge.id]|default(0) > 0 ? 1 : 0 }}"
                            class="js-edge-input"
                        />
                        <label
                            class="button button--large button--toggle js-edge-select{% if selected[edge.id]|default(0) > 0 %} edge-toggle__button--active{% endif %}"
                            for="edge_{{ edge.id }}"
                            aria-label="Toggle {{ edge.name }}"
                            aria-pressed="{{ selected[edge.id]|default(0) > 0 ? 'true' : 'false' }}"
                        >Selected</label>
                    </div>
                    {% endif %}
                </div>
            </div>
        </div>
        {% endfor %}
    </div>
</section>
{% endfor %}

{% endblock %}
