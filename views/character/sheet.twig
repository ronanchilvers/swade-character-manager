{% extends 'layouts/default.twig' %}

{% do add_stylesheet('/css/sheet.css') %}
{% do add_script('/javascript/sheet.js') %}

{% set back_url = get_url('characters_concept', {hash: entity.hash}) %}

{% macro die_strip(faces, selected) %}
    <span class="sheet__die-strip">
    {% for face in faces %}
        <span class="sheet__die-strip__step{% if selected == face %} sheet__die-strip__step--active{% endif %}">{{ face }}</span>
    {% endfor %}
    </span>
{% endmacro %}

{% macro empty_lines(count) %}
    {% for _ in 1..count %}
        <li class="sheet__list__row sheet__list__row--empty">&nbsp;</li>
    {% endfor %}
{% endmacro %}

{% macro gear_row(item) %}
    <li class="sheet__list__row sheet__gear__row" data-gear-row>
        <span class="sheet__gear__name"
              contenteditable="true"
              data-cell="name"
              data-placeholder="Add gear…">{{ item.name ?? '' }}</span>
        <button class="sheet__row__remove"
                type="button"
                aria-label="Remove gear row">&times;</button>
    </li>
{% endmacro %}

{% macro weapon_row(weapon) %}
    <tr class="sheet__weapons__row" data-weapon-row>
        <td contenteditable="true" data-cell="name" data-placeholder="Weapon name">{{ weapon.name ?? '' }}</td>
        <td contenteditable="true" data-cell="range">{{ weapon.range ?? '' }}</td>
        <td contenteditable="true" data-cell="damage">{{ weapon.damage ?? '' }}</td>
        <td contenteditable="true" data-cell="ap">{{ weapon.ap ?? '' }}</td>
        <td contenteditable="true" data-cell="rof">{{ weapon.rof ?? '' }}</td>
        <td contenteditable="true" data-cell="weight">{{ weapon.weight ?? '' }}</td>
        <td contenteditable="true" data-cell="notes" class="sheet__weapons__notes-cell">{{ weapon.notes ?? '' }}</td>
        <td class="sheet__weapons__actions-cell">
            <button class="sheet__row__remove"
                    type="button"
                    aria-label="Remove weapon row">&times;</button>
        </td>
    </tr>
{% endmacro %}

{% import _self as m %}

{% block content %}
<section class="sheet"
         data-character-hash="{{ entity.hash }}"
         data-sheet-root>

    <header class="sheet__topbar">
        <a class="button" href="{{ back_url }}">&laquo; Back to builder</a>
        <span class="sheet__status" data-sheet-status aria-live="polite"></span>
    </header>

    <div class="sheet__top">
        <div class="sheet__panel sheet__panel--torn sheet__attributes">
            <h2 class="sheet__title">Attributes</h2>
            <ul class="sheet__attributes__list">
                {% for attr in sheet.attributes %}
                <li class="sheet__attributes__row">
                    <span class="sheet__attributes__die">{{ attr.die ? 'd' ~ attr.die : '—' }}</span>
                    <span class="sheet__attributes__max">{{ attr.max ? 'd' ~ attr.max : '—' }}</span>
                    <span class="sheet__attributes__label">{{ attr.label|upper }}</span>
                </li>
                {% endfor %}
            </ul>
        </div>

        <div class="sheet__panel sheet__identity">
            <dl class="sheet__identity__grid">
                <div class="sheet__identity__row">
                    <dt>Name</dt>
                    <dd>{{ sheet.identity.name }}</dd>
                </div>
                <div class="sheet__identity__row">
                    <dt>Race</dt>
                    <dd>Human</dd>
                </div>
                <div class="sheet__identity__row">
                    <dt>Concept</dt>
                    <dd>{{ sheet.identity.concept }}</dd>
                </div>
            </dl>

            <div class="sheet__traits-circles">
                <div class="sheet__circle sheet__circle--editable sheet__circle--bennies">
                    <span class="sheet__circle__value"
                          data-counter="bennies"
                          role="spinbutton"
                          tabindex="0"
                          aria-valuenow="{{ sheet.state.bennies }}"
                          aria-valuemin="0">{{ sheet.state.bennies }}</span>
                    <span class="sheet__circle__label">Bennies</span>
                </div>
                <div class="sheet__circle">
                    <span class="sheet__circle__value">{{ sheet.identity.pace ?? '—' }}</span>
                    <span class="sheet__circle__label">Pace</span>
                </div>
                <div class="sheet__circle">
                    <span class="sheet__circle__value">{{ sheet.identity.parry ?? '—' }}</span>
                    <span class="sheet__circle__label">Parry</span>
                </div>
                <div class="sheet__circle">
                    <span class="sheet__circle__value">{{ sheet.identity.toughness ?? '—' }}</span>
                    <span class="sheet__circle__label">Toughness</span>
                </div>
            </div>
        </div>
    </div>

    <div class="sheet__middle">
        <div class="sheet__panel sheet__panel--torn sheet__skills">
            <h2 class="sheet__title">Skills</h2>
            <ul class="sheet__skills__list">
                {% for skill in sheet.skills %}
                <li class="sheet__skills__row{% if skill.is_core %} sheet__skills__row--core{% endif %}">
                    {{ m.die_strip(skill.die_faces, skill.die) }}
                    <span class="sheet__skills__name">{{ skill.name }}</span>
                    <span class="sheet__skills__attribute">{{ skill.linked_attribute|capitalize }}</span>
                </li>
                {% endfor %}
                {# {% if sheet.skills|length < 20 %}
                    {{ m.empty_lines(20 - sheet.skills|length) }}
                {% endif %} #}
            </ul>
        </div>

        <div class="sheet__panel sheet__gear">
            <h2 class="sheet__title">Gear</h2>
            <ul class="sheet__list sheet__gear__list" data-editable="gear">
                {% for item in sheet.gear %}
                    {{ m.gear_row(item) }}
                {% endfor %}
                <li class="sheet__list__row sheet__list__row--add">
                    <button class="sheet__row__add" type="button" data-add="gear">+ Add gear</button>
                </li>
            </ul>
            <template data-row-template="gear">
                {{ m.gear_row({name: '', notes: ''}) }}
            </template>
        </div>

        <div class="sheet__right">
            <div class="sheet__panel sheet__panel--torn sheet__hindrances">
                <h2 class="sheet__title">Hindrances</h2>
                <ul class="sheet__list">
                    {% for hindrance in sheet.hindrances %}
                    <li class="sheet__list__row">
                        <span class="sheet__hindrances__name">{{ hindrance.name }}</span>
                        <span class="sheet__hindrances__level sheet__hindrances__level--{{ hindrance.level }}">
                            {{ hindrance.level|title }}
                        </span>
                    </li>
                    {% endfor %}
                    {{ m.empty_lines(1) }}
                    {# {% if sheet.hindrances|length < 5 %}
                        {{ m.empty_lines(5 - sheet.hindrances|length) }}
                    {% endif %} #}
                </ul>
            </div>

            <div class="sheet__panel sheet__panel--torn sheet__edges">
                <h2 class="sheet__title">Edges &amp; Advances</h2>
                <ul class="sheet__list">
                    {% for edge in sheet.edges %}
                    <li class="sheet__list__row">
                        <span class="sheet__edges__name">{{ edge.name }}</span>
                        {% if edge.count > 1 %}
                        <span class="sheet__edges__count">&times;{{ edge.count }}</span>
                        {% endif %}
                    </li>
                    {% endfor %}
                </ul>

                <ul class="sheet__advances">
                    {% for tier in ['N','N','N','S','S','S','S','V','V','V','V','H','H','H','H','L','L','L','L'] %}
                    <li class="sheet__advances__row">
                        <span class="sheet__advances__tier">{{ tier }}</span>
                        <span class="sheet__advances__line">&nbsp;</span>
                    </li>
                    {% endfor %}
                </ul>
            </div>
        </div>

        <aside class="sheet__rail sheet__panel sheet__rail--wounds">
            <span class="sheet__rail__label">Wounds</span>
            <ul class="sheet__rail__list">
                {% for n in 1..3 %}
                <li class="sheet__rail__list__item{% if sheet.state.wounds >= n %} sheet__rail__list__item--selected{% endif %}"
                    data-rail="wounds"
                    data-rail-step="{{ n }}">&minus;1</li>
                {% endfor %}
                <li class="sheet__rail__list__item sheet__rail__list__item--inc{% if sheet.state.incapacitated %} sheet__rail__list__item--selected{% endif %}"
                    data-rail="incapacitated">Inc</li>
                {% for n in 1..2 %}
                <li class="sheet__rail__list__item{% if sheet.state.fatigue >= n %} sheet__rail__list__item--selected{% endif %}"
                    data-rail="fatigue"
                    data-rail-step="{{ n }}">&minus;1</li>
                {% endfor %}
            </ul>
            <span class="sheet__rail__label">Fatigue</span>
        </aside>
    </div>

    <div class="sheet__bottom">
        <div class="sheet__panel sheet__weapons">
            <h2 class="sheet__title">Weapon</h2>
            <table class="sheet__weapons__table" data-editable="weapons">
                <thead>
                    <tr>
                        <th class="sheet__weapons__table__name">Name</th>
                        <th class="sheet__weapons__table__range">Range</th>
                        <th class="sheet__weapons__table__damage">Damage</th>
                        <th class="sheet__weapons__table__ap">AP</th>
                        <th class="sheet__weapons__table__rof">RoF</th>
                        <th class="sheet__weapons__table__wt">WT</th>
                        <th class="sheet__weapons__table__notes">Notes</th>
                        <th class="sheet__weapons__table__actions" aria-hidden="true"></th>
                    </tr>
                </thead>
                <tbody>
                    {% for weapon in sheet.weapons %}
                        {{ m.weapon_row(weapon) }}
                    {% endfor %}
                </tbody>
                <tfoot>
                    <tr>
                        <td colspan="8" class="sheet__weapons__add-cell">
                            <button class="sheet__row__add" type="button" data-add="weapons">+ Add weapon</button>
                        </td>
                    </tr>
                </tfoot>
            </table>
            <template data-row-template="weapons">
                {{ m.weapon_row({name: '', range: '', damage: '', ap: '', rof: '', weight: '', notes: ''}) }}
            </template>
        </div>
    </div>
</section>
{% endblock %}
