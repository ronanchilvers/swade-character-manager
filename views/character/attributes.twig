{% extends 'layouts/character/builder.twig' %}

{% block page %}
<div class="panel">
    <h2 class="panel__title">Attributes</h2>
    <div class="panel__content">
    <p>Mauris congue, ante eu feugiat facilisis, nunc felis sagittis dui,
    vitae maximus ante eros sed quam. Suspendisse consequat, risus eget
    commodo tincidunt, diam mauris luctus mi, eu dapibus erat dolor sit
    amet felis. Quisque vitae mollis tellus, a mattis risus. Ut ullamcorper
    dolor ut placerat volutpat. Curabitur luctus cursus ligula, ut fringilla
    erat placerat eget.</p>
    </div>
</div>

<form class="form" method="post" action="{{ get_url('characters_attributes', {hash: entity.hash}) }}">

    <div class="cards">
        {% for field, attribute in attribute_fields %}
        <div class="card card--nar2row">
            <div class="card__inner">
                <div class="card__title">{{ attribute.name }}</div>
                <div class="card__content">
                    {{ attribute.description }}
                </div>
                <div class="card__footer">
                    <select class="field__input" id="attribute_{{ field }}" name="attributes[{{ field }}]">
                        {% for value in attribute_options %}
                        <option value="{{ value }}" {% if attribute(entity, field) == value %}selected{% endif %}>d{{ value }}</option>
                        {% endfor %}
                    </select>
                </div>
            </div>
        </div>
    {% endfor %}
    </div>

    <div class="form__buttons form__buttons--floating">
        <a class="button" href="{{ get_url('characters_hindrances', {hash: entity.hash}) }}">Previous</a>
        <button class="button button--primary" type="submit">Save and Continue...</button>
    </div>

</form>
{% endblock %}
