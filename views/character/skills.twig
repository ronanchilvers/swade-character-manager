{% extends 'layouts/character/builder.twig' %}

{#% do add_script('/javascript/skills.js') %#}

{% set selected_keys = selected|keys %}

{% block page %}

<div class="panel">
    <h2 class="panel__title">Skills</h2>
    <div class="panel__content">
    <p>Mauris congue, ante eu feugiat facilisis, nunc felis sagittis dui,
    vitae maximus ante eros sed quam. Suspendisse consequat, risus eget
    commodo tincidunt, diam mauris luctus mi, eu dapibus erat dolor sit
    amet felis. Quisque vitae mollis tellus, a mattis risus. Ut ullamcorper
    dolor ut placerat volutpat. Curabitur luctus cursus ligula, ut fringilla
    erat placerat eget.</p>
    </div>
</div>

<form class="form" method="post" action="{{ get_url('characters_skills', {hash: entity.hash}) }}">

    <div class="cards">
        {% for skill in skills %}
        <div class="card">
            <div class="card__inner">
                <div class="card__title" for="skill_{{ skill.id }}">{{ skill.name }} ({{ skill.linked_attribute }})</div>
                <div class="card__content">
                    {% if skill.summary %}
                    <p>{{ skill.summary }}</p>
                    {% endif %}
                    {% if skill.core_skill %}
                    <p>Core skill: starts at d4 for free.</p>
                    {% endif %}
                </div>
                <div class="card__footer">
                    <select
                        class="field__input js-skill-die"
                        id="skill_{{ skill.id }}"
                        name="skills[{{ skill.id }}]"
                        data-linked-attribute-die="{{ group.attribute_die }}"
                        data-baseline-die="{{ skill.core_skill ? 4 : 0 }}"
                    >
                        {% set isSelected = skill.id in selected_keys %}
                    {% for value in dice_options %}
                        {% if (isSelected and 0 == value) or (skill.core_skill and 0 == value) %}
                        {% else %}
                        <option value="{{ value }}" {% if selected[skill.id] and selected[skill.id] == value %}selected{% endif %}>
                            {% if value == 0 %}
                            Untrained
                            {% else %}
                            d{{ value }}
                            {% endif %}
                        </option>
                        {% endif %}
                    {% endfor %}
                    </select>
                </div>
            </div>
        </div>
        {% endfor %}
    </div>

    <div class="form__buttons form__buttons--floating">
        <a class="button" href="{{ get_url('characters_attributes', {hash: entity.hash}) }}">Previous</a>
        <button class="button button--primary" type="submit">Save Skills</button>
    </div>

</form>
{% endblock %}
