{
  "name": "swade-character-creator",
  "author": "Ronan Chilvers <ronan@thelittledot.com>",
  "devDependencies": {
    "sass": "^1.98.0",
    "chokidar-cli": "^3.0.0"
  },
  "scripts": {
    "sass-dev-watch": "SHELL=/bin/sh chokidar 'resources/sass/**/*.scss' --shell /bin/sh -c 'npm run sass-dev'",
    "sass-dev": "./node_modules/.bin/sass --update --style=expanded resources/sass:web/css",
    "sass-prod": "./node_modules/.bin/sass --no-source-map --style=compressed resources/sass:web/css"
  }
}
