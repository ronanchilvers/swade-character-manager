{
  "name": "ronanchilvers/swade-character-manager",
  "type": "project",
  "require": {
    "php": "^8.5",
    "flightphp/core": "^3.18",
    "flightphp/container": "^1.3",
    "twig/twig": "^3.23",
    "ronanchilvers/utility": "^2.0",
    "respect/validation": "^3.1",
    "league/oauth2-google": "^4.2",
    "defuse/php-encryption": "^2.4"
  },
  "autoload": {
    "psr-4": {
      "App\\": "src/"
    }
  },
  "authors": [
    {
      "name": "Ronan Chilvers",
      "email": "ronan@thelittedot.com"
    }
  ],
  "require-dev": {
