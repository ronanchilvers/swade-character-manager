{
  "name": "ronanchilvers/swade-character-manager",
  "type": "project",
  "require": {
    "php": "^8.5",
    "defuse/php-encryption": "^2.4",
    "flightphp/container": "^1.3",
    "flightphp/core": "^3.18",
    "league/oauth2-google": "^4.2",
    "respect/validation": "^3.1",
    "ronanchilvers/utility": "^2.0",
    "twig/twig": "^3.23"
  },
  "autoload": {
    "psr-4": {
      "App\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "authors": [
    {
      "name": "Ronan Chilvers",
      "email": "ronan@thelittedot.com"
    }
  ],
  "require-dev": {
    "flightphp/tracy-extensions": "^0.2.7",
    "phpunit/phpunit": "^13.0",
    "tracy/tracy": "^2.11"
  },
  "scripts": {
    "serve": "cd web && /opt/homebrew/bin/php -S 127.0.0.1:8080 index_dev.php",
    "seed:edges": "@php scripts/seed.php edges core",
    "seed:hindrances": "@php scripts/seed.php hindrances core",
    "seed:skills": "@php scripts/seed.php skills core"
  },
  "config": {
      "process-timeout" : 0,
      "sort-packages": true
  }
}
